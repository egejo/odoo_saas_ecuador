<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_l10n_ec_sri" model="ir.ui.view">
        <field name="name">account.move.form.inherit.l10n.ec.sri</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Header Buttons -->
            <xpath expr="//header" position="inside">
                 <button name="action_send_sri" string="Send to SRI" type="object" class="oe_highlight"
                         invisible="state != 'posted' or l10n_ec_sri_status in ('sent', 'authorized')"/>
                 <button name="action_check_sri" string="Check SRI Status" type="object"
                         invisible="l10n_ec_sri_status != 'sent'"/>
            </xpath>

            <!-- Notebook Page -->
            <xpath expr="//notebook" position="inside">
                <page string="SRI Electronics" name="sri_electronics">
                    <group>
                        <group>
                            <field name="l10n_ec_sri_status" widget="Badge"
                                   decoration-success="l10n_ec_sri_status == 'authorized'"
                                   decoration-danger="l10n_ec_sri_status == 'rejected'"
                                   decoration-info="l10n_ec_sri_status == 'sent'"/>
                            <field name="l10n_ec_sri_access_key"/>
                            <field name="l10n_ec_authorization_date"/>
                        </group>
                        <group>
                            <field name="l10n_ec_sri_error" readonly="1" invisible="not l10n_ec_sri_error"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
