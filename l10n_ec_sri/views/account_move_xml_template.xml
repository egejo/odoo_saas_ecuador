<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="xml_invoice_v_2_26">
<factura id="comprobante" version="2.1.0">
    <infoTributaria>
        <ambiente><t t-esc="record.company_id.l10n_ec_sri_environment"/></ambiente>
        <tipoEmision>1</tipoEmision>
        <razonSocial><t t-esc="record.company_id.name"/></razonSocial>
        <nombreComercial><t t-esc="record.company_id.name"/></nombreComercial>
        <ruc><t t-esc="record.company_id.vat"/></ruc>
        <claveAcceso><t t-esc="access_key"/></claveAcceso>
        <codDoc>01</codDoc>
        <estab>001</estab>
        <ptoEmi>001</ptoEmi>
        <secuencial><t t-esc="record.name.split('-')[-1]"/></secuencial>
        <dirMatriz><t t-esc="record.company_id.street"/></dirMatriz>
    </infoTributaria>
    <infoFactura>
        <fechaEmision><t t-esc="record.invoice_date.strftime('%d/%m/%Y')"/></fechaEmision>
        <dirEstablecimiento><t t-esc="record.company_id.street"/></dirEstablecimiento>
        <obligadoContabilidad><t t-if="record.company_id.l10n_ec_forced_accounting">SI</t><t t-else="">NO</t></obligadoContabilidad>
        <tipoIdentificacionComprador>05</tipoIdentificacionComprador>
        <razonSocialComprador><t t-esc="record.partner_id.name"/></razonSocialComprador>
        <identificacionComprador><t t-esc="record.partner_id.vat"/></identificacionComprador>
        <totalSinImpuestos><t t-esc="'{:.2f}'.format(record.amount_untaxed)"/></totalSinImpuestos>
        <totalDescuento>0.00</totalDescuento>
        <totalConImpuestos>
             <!-- Loop Taxes -->
        </totalConImpuestos>
        <propina>0.00</propina>
        <importeTotal><t t-esc="'{:.2f}'.format(record.amount_total)"/></importeTotal>
        <moneda>DOLAR</moneda>
    </infoFactura>
    <detalles>
        <detalle t-foreach="record.invoice_line_ids" t-as="line">
            <codigoPrincipal><t t-esc="line.product_id.default_code or 'GEN'"/></codigoPrincipal>
            <descripcion><t t-esc="line.name"/></descripcion>
            <cantidad><t t-esc="line.quantity"/></cantidad>
            <precioUnitario><t t-esc="line.price_unit"/></precioUnitario>
            <descuento>0.00</descuento>
            <precioTotalSinImpuesto><t t-esc="line.price_subtotal"/></precioTotalSinImpuesto>
            <impuestos>
                 <!-- Tax Logic -->
            </impuestos>
        </detalle>
    </detalles>
</factura>
</template>
</odoo>
