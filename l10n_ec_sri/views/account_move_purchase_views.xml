<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_l10n_ec_purchase" model="ir.ui.view">
        <field name="name">account.move.form.inherit.l10n.ec.purchase</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Smart Button -->
            <div name="button_box" position="inside">
                <button name="action_view_retentions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-list-alt"
                        invisible="l10n_ec_retention_count == 0 or move_type != 'in_invoice'">
                    <field name="l10n_ec_retention_count" widget="statinfo" string="Retentions"/>
                </button>
            </div>

            <!-- Action Button -->
            <xpath expr="//header" position="inside">
                <button name="action_create_retention"
                        string="Add Retention"
                        type="object"
                        class="oe_highlight"
                        invisible="move_type != 'in_invoice' or state != 'posted'"/>
            </xpath>
        </field>
    </record>
</odoo>
