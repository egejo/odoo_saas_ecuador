<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- RIDE (Representacion Impresa de Documento Electronico): bloque de
         identificacion legal exigido por el SRI (razon social, RUC,
         ambiente, tipo/numero de comprobante, clave de acceso + codigo de
         barras, numero de autorizacion). Sin este bloque, el PDF impreso
         no es un RIDE valido aunque el XML ya este autorizado por el SRI. -->
    <template id="report_invoice_header">
        <!-- Separador fijo, NO decorativo: wkhtmltopdf renderiza el
             ".header" (logo+direccion+RUC de la empresa) como una capa
             independiente sobre el margen superior de la pagina (ver
             ir_actions_report._prepare_html), no como flujo normal de
             documento. Si el bloque que antecede a este template no deja
             suficiente alto (p.ej. al vaciar los divs de direccion del
             cliente para no repetirlo dos veces, ver mas abajo), ese
             ".header" queda pisando el inicio del cuerpo; un margin-top
             en la tabla de abajo NO alcanza a corregirlo porque el
             ".header" no forma parte del mismo flujo. Probado: sin este
             div, "RUC: ..." de la empresa se superpone con el titulo
             "ADRENASPORTS CIA. LTDA." de abajo.-->
        <div style="height: 20mm; width: 100%;"><br/></div>
        <table class="table table-borderless w-100 m-1">
            <tr>
                <td class="pe-1" style="width: 45%">
                    <table class="table table-borderless">
                        <tr>
                            <td class="p-1">
                                <h4 style="letter-spacing: 1px;">
                                    <span t-esc="o.company_id.l10n_ec_commercial_name or o.company_id.name"/>
                                </h4>
                                <div style="font-size: 12px;">
                                    <strong>RUC: </strong>
                                    <span t-field="o.company_id.partner_id.vat"/>
                                    <br/>
                                    <t t-if="o.journal_id.l10n_ec_emission_address_id">
                                        <strong>Dirección Matriz/Sucursal: </strong>
                                        <span t-esc="o.journal_id.l10n_ec_emission_address_id._display_address()"/>
                                        <br/>
                                    </t>
                                    <strong>Ambiente: </strong>
                                    <t t-if="o.company_id.l10n_ec_sri_environment == 'production'">PRODUCCIÓN</t>
                                    <t t-else="">PRUEBAS</t>
                                    <br/>
                                    <strong>Emisión: </strong>NORMAL
                                    <br/>
                                    <strong>Obligado a Llevar Contabilidad: </strong>
                                    <t t-if="o.company_id.l10n_ec_forced_accounting">SÍ</t>
                                    <t t-else="">NO</t>
                                    <br/>
                                    <t t-if="o.company_id.l10n_ec_special_resolution">
                                        <strong>Contribuyente Especial Res. No.: </strong>
                                        <span t-field="o.company_id.l10n_ec_special_resolution"/>
                                        <br/>
                                    </t>
                                    <t t-if="o.company_id.l10n_ec_withhold_agent">
                                        <strong>Agente de Retención Res. No.: </strong>
                                        <span t-field="o.company_id.l10n_ec_withhold_resolution"/>
                                        <br/>
                                    </t>
                                </div>
                            </td>
                        </tr>
                    </table>
                </td>
                <td class="p-1" style="width: 55%">
                    <table class="table table-condensed m-1">
                        <tr>
                            <td class="text-center border-top-0 p-1">
                                <h4 style="letter-spacing: 1px;">
                                    <span t-esc="o.l10n_latam_document_type_id.report_name or o.l10n_latam_document_type_id.name"/>
                                    <br/>
                                    <span t-esc="o.l10n_latam_document_number or o.name"/>
                                </h4>
                                <t t-if="o.l10n_ec_sri_status == 'authorized'">
                                    <div class="text-center" style="font-size: 12px">
                                        <strong>Número de Autorización: </strong>
                                        <span t-field="o.l10n_ec_sri_access_key"/>
                                    </div>
                                    <div t-if="o.l10n_ec_authorization_date" class="text-center" style="font-size: 12px">
                                        <strong>Fecha y Hora de Autorización: </strong>
                                        <span t-field="o.l10n_ec_authorization_date"/>
                                    </div>
                                    <div class="text-center">
                                        <img style="width:100%; height:15mm;"
                                            t-att-src="'/report/barcode/Code128/' + o.l10n_ec_sri_access_key"
                                            alt="Código de barras: clave de acceso"
                                        />
                                    </div>
                                    <div class="text-center" style="font-size: 11px">
                                        <strong>Clave de Acceso: </strong>
                                        <span t-field="o.l10n_ec_sri_access_key"/>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="text-center bg-danger text-white p-2" style="font-size: 13px;">
                                        <strong>
                                            DOCUMENTO NO AUTORIZADO POR EL SRI
                                            <span t-if="o.l10n_ec_sri_status"> (<span t-esc="o.l10n_ec_sri_status.upper()"/>)</span>
                                        </strong>
                                        <div>Este comprobante no tiene validez tributaria hasta ser autorizado.</div>
                                    </div>
                                </t>
                            </td>
                        </tr>
                    </table>
                </td>
            </tr>
        </table>
    </template>

    <template id="report_invoice_document" inherit_id="account.report_invoice_document" primary="True">

        <!-- Reemplaza el titulo generico ("Invoice"/"Credit Note") por el
             bloque RIDE completo. -->
        <xpath expr="//t[@t-set='layout_document_title']" position="replace">
            <t t-call="l10n_ec_sri.report_invoice_header"/>
        </xpath>

        <!-- El bloque de direccion grande que Odoo pone justo debajo del
             titulo queda mal ubicado ahora: la caja RIDE ya ocupa ese
             espacio y los datos del cliente se muestran mas abajo, en la
             fila "informations". Se quita para no repetir al cliente dos
             veces con estilos distintos (mismo criterio que l10n_ec_edi de
             Enterprise y l10n_cl). -->
        <xpath expr="//div[@name='address_not_same_as_shipping']" position="replace">
            <div name="address_not_same_as_shipping"/>
        </xpath>
        <xpath expr="//div[@name='address_same_as_shipping']" position="replace">
            <div name="address_same_as_shipping"/>
        </xpath>
        <xpath expr="//div[@name='no_shipping']" position="replace">
            <div name="no_shipping"/>
        </xpath>

        <xpath expr="//div[@id='informations']/*" position="before">
            <div class="col" name="l10n_ec_partner_info">
                <strong>Cliente</strong>
                <div t-esc="o.partner_id.name"/>
                <div t-if="o.partner_id.vat">
                    <t t-if="o.partner_id.l10n_latam_identification_type_id" t-esc="o.partner_id.l10n_latam_identification_type_id.name"/>
                    <t t-else="">RUC/Cédula</t>: <span t-field="o.partner_id.vat"/>
                </div>
                <div t-esc="o.partner_id._display_address(without_company=True)"/>
            </div>
            <div class="col" name="l10n_ec_modified_document" t-if="o.reversed_entry_id">
                <strong>Comprobante Modificado</strong>
                <div t-esc="o.reversed_entry_id.l10n_latam_document_number or o.reversed_entry_id.name"/>
            </div>
            <div class="col" name="l10n_ec_modified_document_date" t-if="o.reversed_entry_id">
                <strong>Fecha Emisión Doc. Modificado</strong>
                <div t-field="o.reversed_entry_id.invoice_date"/>
            </div>
            <div class="col" name="l10n_ec_modification_reason" t-if="o.reversed_entry_id and o.narration">
                <strong>Motivo</strong>
                <div t-field="o.narration"/>
            </div>
        </xpath>

        <!-- Formas de pago e informacion adicional: el SRI exige mostrar la
             forma de pago en el RIDE, y por convencion (ver l10n_ec_edi de
             Enterprise) tambien referencia/vendedor/email de contacto. -->
        <xpath expr="//div[@id='payment_term']" position="after">
            <t t-set="l10n_ec_payment_data" t-value="o._l10n_ec_get_payment_data()"/>
            <t t-set="l10n_ec_additional_info" t-value="o._l10n_ec_get_invoice_additional_info()"/>
            <!-- Tabla exterior con anchos fijos en vez de row/col-* de
                 Bootstrap: wkhtmltopdf no soporta flexbox y el grid
                 flotante de Bootstrap no respeta el ancho de columna aqui,
                 haciendo que las dos tablas internas se superpongan. -->
            <table class="table table-borderless w-100" style="table-layout: fixed;" t-if="l10n_ec_payment_data or l10n_ec_additional_info">
                <tr>
                    <td style="width: 50%; vertical-align: top;" t-if="l10n_ec_payment_data" name="l10n_ec_payment_methods">
                        <table class="table table-sm table-borderless" style="page-break-inside: avoid">
                            <thead>
                                <tr>
                                    <th class="text-center" colspan="2">Forma de Pago</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="l10n_ec_payment_data" t-as="payment">
                                    <td t-esc="payment['payment_name']"/>
                                    <td class="text-end">
                                        <span t-esc="payment['payment_total']"
                                            t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </td>
                    <td t-else="" style="width: 50%"/>
                    <td style="width: 50%; vertical-align: top;" t-if="l10n_ec_additional_info" name="l10n_ec_additional_info">
                        <table class="table table-sm table-borderless" style="page-break-inside: avoid">
                            <thead>
                                <tr>
                                    <th class="text-center" colspan="2">Información Adicional</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="l10n_ec_additional_info.items()" t-as="item">
                                    <tr t-if="item[1]">
                                        <td t-esc="item[0]"/>
                                        <td t-esc="item[1]"/>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </td>
                    <td t-else="" style="width: 50%"/>
                </tr>
            </table>
        </xpath>
    </template>

    <!-- Sin esto, account.report_invoice nunca invoca el template de
         arriba: su t-if solo llama a account.report_invoice_document
         cuando _get_name_invoice_report() devuelve ese nombre generico. -->
    <template id="report_invoice" inherit_id="account.report_invoice">
        <xpath expr="//t[@t-call='account.report_invoice_document']" position="after">
            <t t-if="o._get_name_invoice_report() == 'l10n_ec_sri.report_invoice_document'"
               t-call="l10n_ec_sri.report_invoice_document"
               t-lang="lang"/>
        </xpath>
    </template>

</odoo>
