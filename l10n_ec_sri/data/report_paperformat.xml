<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        El paperformat por defecto de la empresa reserva 52mm de margen
        superior con header_spacing=52, pensado para el encabezado
        completo (logo+tagline+direccion/RUC) de
        web.external_layout_standard. El RIDE usa su propio layout
        (external_layout_ride en report/report_invoice.xml) con la zona de
        header de wkhtmltopdf completamente vacia: el logo vive dentro
        del recuadro con bordes de report_invoice_header, en el cuerpo del
        documento, no en esa zona; asi que no hace falta reservar
        espacio para header_spacing. Se define un paperformat propio y se
        asigna unicamente a las acciones de impresion de factura/nota de
        credito (no al paperformat_id de la empresa, que sigue aplicando
        sin cambios al resto de reportes).

        margin_top sigue corriendo el cuerpo del documento hacia abajo
        desde el borde superior de la pagina (aqui, un margen superior
        normal de pagina); header_spacing en 0 porque no hay nada que
        mostrar en la zona de header.
    -->
    <record id="paperformat_ride" model="report.paperformat">
        <field name="name">SRI RIDE</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">32</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <!-- account.report_invoice es el nombre del template QWeb, no de la
         accion de impresion: hay dos acciones reales que renderizan
         facturas ("Invoice PDF" con pagos, y "PDF without Payment"), y el
         boton "Imprimir" del formulario puede resolver a cualquiera de
         las dos segun version/config. Se fija el paperformat en ambas. -->
    <record id="account.account_invoices" model="ir.actions.report">
        <field name="paperformat_id" ref="l10n_ec_sri.paperformat_ride"/>
    </record>
    <record id="account.account_invoices_without_payment" model="ir.actions.report">
        <field name="paperformat_id" ref="l10n_ec_sri.paperformat_ride"/>
    </record>
</odoo>
