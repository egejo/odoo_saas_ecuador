<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_l10n_ec_edi" model="ir.ui.view">
        <field name="name">res.company.form.l10n_ec_edi</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='branches']" position="after">
                <page string="Ecuador SRI" name="l10n_ec_sri">
                    <group>
                        <group string="Environment &amp; Signature">
                            <field name="l10n_ec_sri_environment"/>
                            <field name="l10n_ec_certificate_id"/>
                            <field name="l10n_ec_commercial_name"/>
                        </group>
                        <group string="Withholding">
                            <field name="l10n_ec_withhold_agent"/>
                            <field name="l10n_ec_withhold_resolution" invisible="not l10n_ec_withhold_agent"/>
                            <field name="l10n_ec_special_resolution"/>
                            <field name="l10n_ec_forced_accounting"/>
                        </group>
                        <group string="Régimen Tributario">
                            <field name="l10n_ec_regime"/>
                        </group>
                    </group>
                    <group string="SRI Web Service URLs">
                        <field name="l10n_ec_sri_reception_url"/>
                        <field name="l10n_ec_sri_authorization_url"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
