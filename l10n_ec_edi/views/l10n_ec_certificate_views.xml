<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_l10n_ec_certificate_form" model="ir.ui.view">
        <field name="name">l10n_ec.certificate.form</field>
        <field name="model">l10n_ec.certificate</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_validate" string="Validate &amp; Activate" type="object" class="oe_highlight" invisible="state == 'active'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id" invisible="1"/>
                            <field name="content" filename="name"/>
                            <field name="password" password="True"/>
                        </group>
                        <group string="Metadata">
                            <field name="subject_cn"/>
                            <field name="issuer_cn"/>
                            <field name="expiration_date"/>
                            <field name="days_until_expiry"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_l10n_ec_certificate" model="ir.actions.act_window">
        <field name="name">Digital Signatures</field>
        <field name="res_model">l10n_ec.certificate</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_l10n_ec_certificate" parent="account.menu_finance_configuration" action="action_l10n_ec_certificate" sequence="100"/>
</odoo>
