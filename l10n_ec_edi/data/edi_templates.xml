<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="l10n_ec_edi_factura">
            <factura id="comprobante" version="2.1.0">
                <infoTributaria>
                    <ambiente t-out="environment"/>
                    <tipoEmision>1</tipoEmision>
                    <razonSocial t-out="company.name[:300]"/>
                    <nombreComercial t-if="company.l10n_ec_commercial_name" t-out="company.l10n_ec_commercial_name[:300]"/>
                    <ruc t-out="company.vat"/>
                    <claveAcceso t-out="access_key"/>
                    <codDoc>01</codDoc>
                    <estab t-out="access_key[24:27]"/>
                    <ptoEmi t-out="access_key[27:30]"/>
                    <secuencial t-out="access_key[30:39]"/>
                    <dirMatriz t-out="company.street[:300]"/>
                    <agenteRetencion t-if="company.l10n_ec_withhold_agent" t-out="company.l10n_ec_withhold_resolution"/>
                </infoTributaria>
                <infoFactura>
                    <fechaEmision t-out="move.invoice_date.strftime('%d/%m/%Y')"/>
                    <dirEstablecimiento t-out="company.street[:300]"/>
                    <contribuyenteEspecial t-if="company.l10n_ec_taxpayer_type == 'special'" t-out="company.l10n_ec_special_resolution"/>
                    <obligadoContabilidad t-out="'SI' if company.l10n_ec_forced_accounting else 'NO'"/>

                    <tipoIdentificacionComprador t-out="l10n_ec_identifier_code"/>
                    <razonSocialComprador t-out="partner.name[:300]"/>
                    <identificacionComprador t-out="partner.vat"/>
                    <direccionComprador t-if="partner.street" t-out="partner.street[:300]"/>
                    <totalSinImpuestos t-out="format_monetary(vals['total_sin_impuestos'])"/>
                    <totalDescuento t-out="format_monetary(vals['total_descuento'])"/>
                    <totalConImpuestos>
                        <t t-foreach="vals['taxes']" t-as="tax">
                            <totalImpuesto>
                                <codigo t-out="tax['codigo']"/>
                                <codigoPorcentaje t-out="tax['codigo_porcentaje']"/>
                                <baseImponible t-out="format_monetary(tax['base'])"/>
                                <valor t-out="format_monetary(tax['amount'])"/>
                            </totalImpuesto>
                        </t>
                    </totalConImpuestos>
                    <propina t-out="format_monetary(0.0)"/>
                    <importeTotal t-out="format_monetary(move.amount_total)"/>
                    <moneda>DOLAR</moneda>
                    <pagos>
                         <t t-foreach="vals['pagos']" t-as="pago">
                            <pago>
                                <formaPago t-out="pago['code']"/>
                                <total t-out="format_monetary(pago['amount'])"/>
                            </pago>
                        </t>
                    </pagos>
                </infoFactura>
                <detalles>
                    <t t-foreach="move.invoice_line_ids.filtered(lambda l: not l.display_type)" t-as="line">
                        <detalle>
                            <codigoPrincipal t-out="line.product_id.default_code[:25] if line.product_id.default_code else 'GEN'"/>
                            <descripcion t-out="line.name[:300].replace('\n', ' ')"/>
                            <cantidad t-out="format_float(line.quantity, 6)"/>
                            <precioUnitario t-out="format_float(line.price_unit, 6)"/>
                            <descuento t-out="format_monetary(line.price_unit * line.quantity * (line.discount / 100.0))"/>
                            <precioTotalSinImpuesto t-out="format_monetary(line.price_subtotal)"/>
                            <impuestos>
                                <t t-foreach="line.tax_ids" t-as="tax_line">
                                    <impuesto>
                                        <codigo>2</codigo> <!-- IVA -->
                                        <codigoPorcentaje t-out="tax_map.get(tax_line.id, '0')"/>
                                        <tarifa t-out="tax_line.amount"/>
                                        <baseImponible t-out="format_monetary(line.price_subtotal)"/> <!-- Simplified: need proportional if multi-tax -->
                                        <valor t-out="format_monetary(line.price_subtotal * (tax_line.amount / 100))"/>
                                    </impuesto>
                                </t>
                            </impuestos>
                        </detalle>
                    </t>
                </detalles>
                <infoAdicional t-if="move.narration or partner.email">
                    <campoAdicional nombre="Email" t-if="partner.email" t-out="partner.email"/>
                    <campoAdicional nombre="Notas" t-if="move.narration" t-out="move.narration[:300]"/>
                </infoAdicional>
            </factura>
        </template>
    </data>
</odoo>
