<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="l10n_ec_guia_xml">
            <guiaRemision id="comprobante" version="1.1.0">
                <infoTributaria>
                    <ambiente t-out="environment"/>
                    <tipoEmision>1</tipoEmision>
                    <razonSocial t-out="company.name[:300]"/>
                    <nombreComercial t-if="company.l10n_ec_commercial_name" t-out="company.l10n_ec_commercial_name[:300]"/>
                    <ruc t-out="company.vat"/>
                    <claveAcceso t-out="access_key"/>
                    <codDoc>06</codDoc>
                    <estab t-out="access_key[24:27]"/>
                    <ptoEmi t-out="access_key[27:30]"/>
                    <secuencial t-out="access_key[30:39]"/>
                    <dirMatriz t-out="company.street[:300]"/>
                </infoTributaria>
                <infoGuiaRemision>
                    <dirEstablecimiento t-out="picking.picking_type_id.warehouse_id.partner_id.street[:300] or company.street[:300]"/>
                    <dirPartida t-out="picking.picking_type_id.warehouse_id.partner_id.street[:300] or company.street[:300]"/>
                    <razonSocialTransportista t-out="picking.l10n_ec_driver_id.name[:300]"/>
                    <tipoIdentificacionTransportista t-out="'05' if picking.l10n_ec_driver_id.identifier_type == 'cedula' else '04'"/>
                    <rucTransportista t-out="picking.l10n_ec_driver_id.license_number"/> <!-- Assuming license is ID -->
                    <placa t-out="picking.l10n_ec_vehicle_id.license_plate"/>
                    <fechaIniTransporte t-out="picking.l10n_ec_start_date.strftime('%d/%m/%Y')"/>
                    <fechaFinTransporte t-out="picking.l10n_ec_end_date.strftime('%d/%m/%Y')"/>
                </infoGuiaRemision>
                <destinatarios>
                    <destinatario>
                        <identificacionDestinatario t-out="picking.partner_id.vat"/>
                        <razonSocialDestinatario t-out="picking.partner_id.name[:300]"/>
                        <dirDestinatario t-out="picking.partner_id.street[:300]"/>
                        <motivoTraslado t-out="picking.l10n_ec_transport_reason"/>
                        <!-- If imported, add DAU logic here -->
                        <detalles>
                            <t t-foreach="picking.move_ids" t-as="move">
                                <detalle>
                                    <codigoInterno t-out="move.product_id.default_code or move.product_id.id"/>
                                    <descripcion t-out="move.product_id.name[:300]"/>
                                    <cantidad t-out="format_float(move.quantity, 2)"/>
                                </detalle>
                            </t>
                        </detalles>
                    </destinatario>
                </destinatarios>
            </guiaRemision>
        </template>
    </data>
</odoo>
