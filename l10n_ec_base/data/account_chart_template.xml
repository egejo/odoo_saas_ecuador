<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Ecuador Tax Groups -->

        <!-- IVA Groups -->
        <record id="tax_group_iva" model="account.tax.group">
            <field name="name">IVA 15%</field>
            <field name="country_id" ref="base.ec"/>
            <field name="sequence">10</field>
        </record>

        <record id="tax_group_iva_0" model="account.tax.group">
            <field name="name">IVA 0%</field>
            <field name="country_id" ref="base.ec"/>
            <field name="sequence">11</field>
        </record>

        <record id="tax_group_iva_exempt" model="account.tax.group">
            <field name="name">Exento de IVA</field>
            <field name="country_id" ref="base.ec"/>
            <field name="sequence">12</field>
        </record>

        <record id="tax_group_iva_5" model="account.tax.group">
            <field name="name">IVA 5% (Construcción)</field>
            <field name="country_id" ref="base.ec"/>
            <field name="sequence">13</field>
        </record>

        <!-- Withholding Groups -->
        <record id="tax_group_ret_ir" model="account.tax.group">
            <field name="name">Retención Fuente IR</field>
            <field name="country_id" ref="base.ec"/>
            <field name="sequence">20</field>
        </record>

        <record id="tax_group_ret_iva" model="account.tax.group">
            <field name="name">Retención IVA</field>
            <field name="country_id" ref="base.ec"/>
            <field name="sequence">21</field>
        </record>

        <!-- Chart Template -->
        <record id="chart_template_ec" model="account.chart.template">
            <field name="name">Ecuador - Plan de Cuentas NEC/NIIF (2026)</field>
            <field name="country_id" ref="base.ec"/>
            <field name="currency_id" ref="base.USD"/>
            <field name="bank_account_code_prefix">1.01.01.03</field>
            <field name="cash_account_code_prefix">1.01.01.01</field>
            <field name="transfer_account_code_prefix">1.01.01.04</field>
            <field name="code_digits">10</field>
        </record>

    </data>
</odoo>
