<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Ecuador Localization Security Groups -->

        <!-- Base Invoicing Roles -->
        <record id="group_l10n_ec_invoice_clerk" model="res.groups">
            <field name="name">Ecuador: Invoice Clerk</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
            <field name="comment">Can create and post invoices, but cannot cancel or modify tax configuration.</field>
        </record>

        <record id="group_l10n_ec_accountant" model="res.groups">
            <field name="name">Ecuador: Accountant</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
            <field name="implied_ids" eval="[(4, ref('group_l10n_ec_invoice_clerk'))]"/>
            <field name="comment">Full accounting access including cancellation and SRI retry.</field>
        </record>

        <!-- AP/AR Roles -->
        <record id="group_l10n_ec_ap_clerk" model="res.groups">
            <field name="name">Ecuador: AP Clerk</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
            <field name="comment">Can create vendor bills and retentions.</field>
        </record>

        <record id="group_l10n_ec_ar_clerk" model="res.groups">
            <field name="name">Ecuador: AR Clerk</field>
            <field name="category_id" ref="base.module_category_accounting_accounting"/>
            <field name="comment">Can create customer invoices only.</field>
        </record>

        <!-- Payroll Roles -->
        <record id="group_l10n_ec_payroll_user" model="res.groups">
            <field name="name">Ecuador: Payroll Specialist</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="comment">Can create and compute payslips, export IESS files.</field>
        </record>

        <record id="group_l10n_ec_hr_manager" model="res.groups">
            <field name="name">Ecuador: HR Manager</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
            <field name="implied_ids" eval="[(4, ref('group_l10n_ec_payroll_user'))]"/>
            <field name="comment">Full HR access including salary modification and contract termination.</field>
        </record>

        <!-- Warehouse Roles -->
        <record id="group_l10n_ec_warehouse_user" model="res.groups">
            <field name="name">Ecuador: Warehouse User</field>
            <field name="category_id" ref="base.module_category_inventory_inventory"/>
            <field name="comment">Can create transfers and Guías de Remisión.</field>
        </record>

        <record id="group_l10n_ec_warehouse_manager" model="res.groups">
            <field name="name">Ecuador: Warehouse Manager</field>
            <field name="category_id" ref="base.module_category_inventory_inventory"/>
            <field name="implied_ids" eval="[(4, ref('group_l10n_ec_warehouse_user'))]"/>
            <field name="comment">Full stock access including cancellation.</field>
        </record>

        <!-- IT Admin (inherits base.group_system) -->
        <record id="group_l10n_ec_it_admin" model="res.groups">
            <field name="name">Ecuador: IT Administrator</field>
            <field name="category_id" ref="base.module_category_administration"/>
            <field name="implied_ids" eval="[(4, ref('base.group_system'))]"/>
            <field name="comment">Full system configuration including P12 certificate management.</field>
        </record>

    </data>
</odoo>
