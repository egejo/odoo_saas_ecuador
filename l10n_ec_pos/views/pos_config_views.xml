<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_config_view_form_inherit_l10n_ec_pos" model="ir.ui.view">
        <field name="name">pos.config.form.inherit.l10n_ec.pos</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Ecuador SRI" name="l10n_ec_sri">
                    <group>
                        <field name="l10n_ec_sri_active"/>
                        <field name="l10n_ec_entity" invisible="not l10n_ec_sri_active"/>
                        <field name="l10n_ec_emission_point" invisible="not l10n_ec_sri_active"/>
                        <field name="l10n_ec_default_partner_id" invisible="not l10n_ec_sri_active"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
