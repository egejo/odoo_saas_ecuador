<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- Bloque RIDE (formato reducido) sobre el ticket de rollo del POS:
         datos obligatorios de la Representacion Impresa del Documento
         Electronico: emisor, receptor, tipo/numero de comprobante,
         fecha, estado SRI, numero de autorizacion/clave de acceso y su
         codigo de barras. Solo se muestra si la orden ya fue facturada
         (ver pos_sri.js, que factura y transmite al validar el pago).

         El recibo base de Odoo (point_of_sale.OrderReceipt) usa un lienzo
         logico de 512px/27px como texto normal (pos_receipts.css), pensado
         para rollo termico de 80mm: este bloque sigue esa misma escala
         relativa en vez de tamanos de pixeles sueltos, para que se vea
         proporcionado al resto del ticket y no minusculo. -->
    <t t-name="l10n_ec_pos.OrderReceiptSriPatch" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//ReceiptHeader" position="after">
            <div t-if="props.data.l10n_ec_sri" class="pos-receipt-order-data l10n-ec-sri-block"
                 style="border-top:2px dashed #000;border-bottom:2px dashed #000;padding:8px 0;margin-bottom:8px;font-size:75%;line-height:1.35;">

                <div style="text-align:center;font-weight:bold;font-size:110%;">
                    <t t-esc="props.data.l10n_ec_sri.document_type"/><br/>
                    Nro. <t t-esc="props.data.l10n_ec_sri.move_name"/>
                </div>

                <div style="text-align:center;margin:4px 0;">
                    RUC: <t t-esc="props.data.headerData.company.vat"/><br/>
                    <t t-if="props.data.l10n_ec_sri.company_street" t-esc="props.data.l10n_ec_sri.company_street"/><br/>
                    Fecha Emisión: <t t-esc="props.data.l10n_ec_sri.invoice_date"/>
                </div>

                <div style="border-top:1px dotted #000;padding-top:4px;">
                    Cliente: <t t-esc="props.data.l10n_ec_sri.partner_name"/><br/>
                    <t t-esc="props.data.l10n_ec_sri.partner_identification_type"/>:
                    <t t-esc="props.data.l10n_ec_sri.partner_vat"/>
                </div>

                <div t-if="props.data.l10n_ec_sri.l10n_ec_sri_status == 'authorized'"
                     style="text-align:center;font-weight:bold;font-size:110%;margin-top:6px;">
                    AUTORIZADO
                    <div style="font-weight:normal;font-size:85%;">
                        <t t-esc="props.data.l10n_ec_sri.l10n_ec_authorization_date"/>
                    </div>
                </div>
                <div t-elif="props.data.l10n_ec_sri.l10n_ec_sri_status == 'sent'"
                     style="text-align:center;font-weight:bold;font-size:110%;margin-top:6px;">
                    PENDIENTE DE AUTORIZACIÓN SRI
                </div>
                <div t-elif="props.data.l10n_ec_sri.l10n_ec_sri_status == 'rejected'"
                     style="text-align:center;font-weight:bold;font-size:110%;margin-top:6px;">
                    RECHAZADO POR EL SRI
                    <div style="font-weight:normal;font-size:85%;" t-esc="props.data.l10n_ec_sri.l10n_ec_sri_error"/>
                </div>

                <div t-if="props.data.l10n_ec_sri.l10n_ec_sri_access_key" style="margin-top:6px;text-align:center;">
                    <div style="font-size:85%;">Núm. Autorización / Clave de Acceso</div>
                    <div style="font-family:monospace;word-break:break-all;font-size:70%;">
                        <t t-esc="props.data.l10n_ec_sri.l10n_ec_sri_access_key"/>
                    </div>
                    <img t-attf-src="/report/barcode/Code128/{{props.data.l10n_ec_sri.l10n_ec_sri_access_key}}?width=280&amp;height=45&amp;humanreadable=0"
                         style="max-width:100%;margin-top:4px;"/>
                </div>
            </div>
        </xpath>
    </t>
</templates>
