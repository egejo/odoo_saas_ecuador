<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- Bloque RIDE (formato reducido) sobre el ticket de rollo del POS:
         datos obligatorios de la Representacion Impresa del Documento
         Electronico: emisor, receptor, tipo/numero de comprobante,
         fecha, estado SRI, numero de autorizacion/clave de acceso y su
         codigo de barras. Solo se muestra si la orden ya fue facturada
         (ver pos_sri.js, que factura y transmite al validar el pago). -->
    <t t-name="l10n_ec_pos.OrderReceiptSriPatch" t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//ReceiptHeader" position="after">
            <div t-if="props.data.l10n_ec_sri" class="pos-receipt-order-data l10n-ec-sri-block"
                 style="border-top:1px dashed #000;border-bottom:1px dashed #000;padding:4px 0;margin-bottom:6px;font-size:11px;">
                <div style="text-align:center;font-weight:bold;">
                    <t t-esc="props.data.l10n_ec_sri.document_type"/>
                    <t t-esc="props.data.l10n_ec_sri.move_name"/>
                </div>
                <div>RUC: <t t-esc="props.data.company.vat"/></div>
                <div t-if="props.data.l10n_ec_sri.company_street" t-esc="props.data.l10n_ec_sri.company_street"/>
                <div>Fecha Emisión: <t t-esc="props.data.l10n_ec_sri.invoice_date"/></div>
                <div>
                    <t t-esc="props.data.l10n_ec_sri.partner_identification_type"/>:
                    <t t-esc="props.data.l10n_ec_sri.partner_vat"/>
                </div>
                <div>Cliente: <t t-esc="props.data.l10n_ec_sri.partner_name"/></div>

                <div t-if="props.data.l10n_ec_sri.l10n_ec_sri_status == 'authorized'" style="text-align:center;font-weight:bold;margin-top:2px;">
                    AUTORIZADO
                    <div style="font-weight:normal;">
                        <t t-esc="props.data.l10n_ec_sri.l10n_ec_authorization_date"/>
                    </div>
                </div>
                <div t-elif="props.data.l10n_ec_sri.l10n_ec_sri_status == 'sent'" style="text-align:center;font-weight:bold;margin-top:2px;">
                    PENDIENTE DE AUTORIZACIÓN SRI
                </div>
                <div t-elif="props.data.l10n_ec_sri.l10n_ec_sri_status == 'rejected'" style="text-align:center;font-weight:bold;margin-top:2px;">
                    RECHAZADO POR EL SRI
                    <div style="font-weight:normal;" t-esc="props.data.l10n_ec_sri.l10n_ec_sri_error"/>
                </div>

                <div t-if="props.data.l10n_ec_sri.l10n_ec_sri_access_key" style="margin-top:2px;">
                    <div>Núm. Autorización / Clave de Acceso:</div>
                    <div style="font-family:monospace;word-break:break-all;font-size:10px;">
                        <t t-esc="props.data.l10n_ec_sri.l10n_ec_sri_access_key"/>
                    </div>
                    <div style="text-align:center;">
                        <img t-attf-src="/report/barcode/Code128/{{props.data.l10n_ec_sri.l10n_ec_sri_access_key}}?width=300&amp;height=50&amp;humanreadable=0" style="max-width:100%;"/>
                    </div>
                </div>
            </div>
        </xpath>
    </t>
</templates>
