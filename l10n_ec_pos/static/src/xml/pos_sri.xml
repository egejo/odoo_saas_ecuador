<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- SRI Receipt Header for POS Tickets -->
    <t t-name="l10n_ec_pos.SriReceiptHeader">
        <div class="sri-header pos-receipt-header">
            <div t-if="receipt.access_key" class="access-key">
                <span class="label">Clave de Acceso:</span>
                <span t-esc="receipt.access_key"/>
            </div>
        </div>
    </t>
</templates>
