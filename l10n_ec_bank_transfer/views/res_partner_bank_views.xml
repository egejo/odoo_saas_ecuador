<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_bank_form_inherit_l10n_ec" model="ir.ui.view">
        <field name="name">res.partner.bank.form.inherit.l10n.ec</field>
        <field name="model">res.partner.bank</field>
        <field name="inherit_id" ref="base.view_partner_bank_form"/>
        <field name="arch" type="xml">
            <field name="acc_number" position="after">
                <field name="l10n_ec_account_type"/>
            </field>
        </field>
    </record>

    <record id="hr_employee_view_form_inherit_l10n_ec_bank" model="ir.ui.view">
        <field name="name">hr.employee.view.form.inherit.l10n.ec.bank</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <field name="bank_account_id" position="after">
                <field name="l10n_ec_bank_id_type"/>
            </field>
        </field>
    </record>
</odoo>
