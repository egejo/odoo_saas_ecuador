<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_l10n_ec_retention_wizard_form" model="ir.ui.view">
        <field name="name">l10n_ec.retention.wizard.form</field>
        <field name="model">l10n_ec.retention.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Withholding">
                <group>
                    <group>
                        <field name="invoice_id" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="date"/>
                    </group>
                </group>
                <notebook>
                    <page string="Lines">
                        <field name="line_ids">
                            <list editable="bottom">
                                <field name="tax_type"/>
                                <field name="tax_code"/>
                                <field name="base"/>
                                <field name="percentage"/>
                                <field name="amount" readonly="1"/>
                                <field name="currency_id" invisible="1"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button string="Create Retention" name="action_create_retention" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_l10n_ec_retention_wizard" model="ir.actions.act_window">
        <field name="name">Add Retention</field>
        <field name="res_model">l10n_ec.retention.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
