<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- TREE VIEW -->
        <record id="view_account_retention_tree" model="ir.ui.view">
            <field name="name">account.retention.tree</field>
            <field name="model">account.retention</field>
            <field name="arch" type="xml">
                <list string="Retentions" decoration-info="state == 'draft'" decoration-muted="state == 'cancel'">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="partner_id"/>
                    <field name="invoice_id"/>
                    <field name="l10n_ec_sri_status" widget="badge" decoration-success="l10n_ec_sri_status == 'authorized'" decoration-danger="l10n_ec_sri_status == 'rejected'"/>
                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'posted'"/>
                </list>
            </field>
        </record>

        <!-- FORM VIEW -->
        <record id="view_account_retention_form" model="ir.ui.view">
            <field name="name">account.retention.form</field>
            <field name="model">account.retention</field>
            <field name="arch" type="xml">
                <form string="Withholding Document">
                    <header>
                        <button name="action_post" string="Post" class="oe_highlight" type="object" invisible="state != 'draft'"/>
                        <button name="action_send_sri" string="Send to SRI" class="oe_highlight" type="object" invisible="l10n_ec_sri_status in ('sent', 'authorized') or state == 'draft'"/>
                        <button name="%(l10n_ec_edi.action_l10n_ec_certificate)d" string="Check Certificate" type="action" groups="base.group_no_one"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,posted"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="partner_id" widget="res_partner_many2one" context="{'show_vat': True}"/>
                                <field name="invoice_id"/>
                            </group>
                            <group>
                                <field name="date"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Withholding Lines">
                                <field name="retention_line_ids">
                                    <list editable="bottom">
                                        <field name="tax_type"/>
                                        <field name="tax_code"/>
                                        <field name="base"/>
                                        <field name="percentage"/>
                                        <field name="amount" sum="Total"/>
                                    </list>
                                </field>
                            </page>
                            <page string="SRI Info">
                                <group>
                                    <field name="l10n_ec_sri_access_key"/>
                                    <field name="l10n_ec_sri_status"/>
                                    <field name="l10n_ec_sri_response"/>
                                    <field name="l10n_ec_xml_data"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <!-- ACTION -->
        <record id="action_account_retention" model="ir.actions.act_window">
            <field name="name">Withholdings</field>
            <field name="res_model">account.retention</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Create a new Withholding Document
              </p>
            </field>
        </record>

        <!-- MENU -->
        <menuitem id="menu_account_retention"
                  name="Withholdings (Retenciones)"
                  parent="account.menu_finance_payables"
                  action="action_account_retention"
                  sequence="20"/>
    </data>
</odoo>
