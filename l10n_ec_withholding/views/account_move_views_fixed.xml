<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_account_move_form_inherit_l10n_ec_withholding_header" model="ir.ui.view">
            <field name="name">account.move.form.inherit.l10n_ec.withholding.header</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="%(l10n_ec_withholding.action_l10n_ec_retention_wizard)d"
                            string="Add Retention"
                            type="action"
                            class="oe_highlight"
                            invisible="move_type != 'in_invoice' or state != 'posted'"/>
                </xpath>
            </field>
        </record>

        <record id="view_account_move_form_inherit_l10n_ec_withholding_field" model="ir.ui.view">
            <field name="name">account.move.form.inherit.l10n_ec.withholding.field</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_date']" position="after">
                    <field name="l10n_ec_sustento_code" invisible="move_type != 'in_invoice'" required="move_type == 'in_invoice'"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
