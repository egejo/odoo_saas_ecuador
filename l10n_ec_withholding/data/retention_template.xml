<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="l10n_ec_retention_xml">
            <comprobanteRetencion id="comprobante" version="2.0.0">
                <infoTributaria>
                    <ambiente t-out="environment"/>
                    <tipoEmision>1</tipoEmision>
                    <razonSocial t-out="company.name[:300]"/>
                    <nombreComercial t-if="company.l10n_ec_commercial_name" t-out="company.l10n_ec_commercial_name[:300]"/>
                    <ruc t-out="company.vat"/>
                    <claveAcceso t-out="access_key"/>
                    <codDoc>07</codDoc>
                    <estab t-out="access_key[24:27]"/>
                    <ptoEmi t-out="access_key[27:30]"/>
                    <secuencial t-out="access_key[30:39]"/>
                    <dirMatriz t-out="company.street[:300]"/>
                    <agenteRetencion t-if="company.l10n_ec_withhold_agent" t-out="company.l10n_ec_withhold_resolution"/>
                </infoTributaria>
                <infoCompRetencion>
                    <fechaEmision t-out="retention.date.strftime('%d/%m/%Y')"/>
                    <dirEstablecimiento t-out="company.street[:300]"/>
                    <contribuyenteEspecial t-if="company.l10n_ec_taxpayer_type == 'special'" t-out="company.l10n_ec_special_resolution"/>
                    <obligadoContabilidad t-out="'SI' if company.l10n_ec_forced_accounting else 'NO'"/>
                    <tipoIdentificacionSujetoRetenido t-out="identifier_code"/>
                    <razonSocialSujetoRetenido t-out="partner.name[:300]"/>
                    <identificacionSujetoRetenido t-out="partner.vat"/>
                    <periodoFiscal t-out="retention.date.strftime('%m/%Y')"/>
                </infoCompRetencion>
                <impuestos>
                    <t t-foreach="retention.retention_line_ids" t-as="line">
                        <impuesto>
                            <codigo t-out="line.tax_type"/>
                            <codigoRetencion t-out="line.tax_code"/>
                            <baseImponible t-out="format_monetary(line.base)"/>
                            <porcentajeRetener t-out="format_float(line.percentage, 2)"/>
                            <valorRetenido t-out="format_monetary(line.amount)"/>
                            <codDocSustento>01</codDocSustento> <!-- Assumed Factura for now, need field on retention line if multi-doc -->
                            <numDocSustento t-out="retention.invoice_id.l10n_latam_document_number.replace('-', '') if retention.invoice_id.l10n_latam_document_number else '000000000000000'"/>
                            <fechaEmisionDocSustento t-out="retention.invoice_id.invoice_date.strftime('%d/%m/%Y') if retention.invoice_id.invoice_date else ''"/>
                        </impuesto>
                    </t>
                </impuestos>
                <infoAdicional t-if="partner.email">
                   <campoAdicional nombre="Email" t-out="partner.email"/>
                </infoAdicional>
            </comprobanteRetencion>
        </template>
    </data>
</odoo>
