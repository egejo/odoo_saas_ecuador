        <!-- ========================================================= -->
        # ISD: RETENCION IMPUESTO A LA SALIDA DE DIVISAS (2026)
        <!-- ========================================================= -->
        <!-- 2026-07-08: auditado (tipo "isd" existia en el modelo desde
             el dia 1 del fork -ver l10n_ec_withholding_tax.py, wizard,
             y _RETENTION_TAX_TYPE_CODE en account_retention.py, codigo
             de cabecera Tabla 19 = 6- pero sin NINGUN registro cargado:
             el desplegable de codigo de retencion quedaba vacio para
             cualquier retencion ISD, imposible de crear en la practica.
             A diferencia de renta/IVA, ISD no tiene una tabla de codigos
             por concepto ni por porcentaje: un unico codigo fijo, 4580,
             para cualquier tarifa (confirmado en la Ficha Tecnica
             oficial del SRI, v2.26, marzo-2024: "Codigo Impuesto ISD =
             4580" en el campo adicional de retenciones). La tarifa SI
             cambia por decreto ejecutivo (5% hasta 2021, bajando
             gradualmente hasta 3.5% en 2023-2024 segun la misma ficha
             tecnica); la vigente para 2026 es 5% de nuevo, fijada por el
             Decreto Ejecutivo No. 272 (30-dic-2025, vigente desde
             01-ene-2026); ese decreto tambien fija tarifas reducidas
             (0%/2.5%) para subpartidas arancelarias especificas de
             sectores farmaceutico/productivo en IMPORTACIONES, un caso
             mas estrecho que no se modela aqui (no hay evidencia de que
             Adrenasports importe bajo esas subpartidas; se puede agregar
             despues si hace falta). -->
        <record id="tax_ret_isd_4580" model="l10n_ec.withholding.tax">
            <field name="code">4580</field>
            <field name="name">Impuesto a la Salida de Divisas (5%)</field>
            <field name="type">isd</field>
            <field name="percentage">5.0</field>
        </record>

    </data>
</odoo>
