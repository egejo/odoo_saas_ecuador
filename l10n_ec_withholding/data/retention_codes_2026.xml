        <!-- ========================================================= -->
        # TABLA 19: RETENCIONES IMPUESTO A LA RENTA (2026)
        <!-- ========================================================= -->

        <!-- RIMPE -->
        <!-- 2026-07-08: auditado contra el catalogo oficial vigente del SRI
             ("Retenciones Marzo 2026", columna "Codigo del Anexo", el
             mismo codigo que usa codigoRetencion en el XML, ver
             retention_template.xml). tax_ret_ir_332b y tax_ret_ir_343a
             tenian el codigo SRI equivocado desde el dia 1 de este fork,
             independientemente de la Resolucion NAC-DGERCGC26-00000009: el
             codigo real de "RIMPE Negocio Popular" es 332 (no 332B, ese
             codigo es "Compra de bienes inmuebles", 0% tambien pero un
             concepto distinto), y el de "RIMPE Emprendedor" es 343 (no
             343A, ese codigo es "Energia electrica"). Antes de la
             resolucion (tabla julio-2025) 343 cubria Energia Electrica Y
             RIMPE Emprendedores juntos al 1%; la resolucion los separo en
             dos codigos con tarifas distintas (343 sigue en 1% solo para
             RIMPE Emprendedor, 343A pasa a su propio codigo al 2% solo
             para Energia Electrica). Se corrige aqui el codigo/nombre de
             estos dos registros (nunca se uso ninguno de los dos en
             produccion, verificado por account.retention.line count = 0
             antes del fix) y se agrega 343A como su propio registro mas
             abajo. -->
        <record id="tax_ret_ir_332b" model="l10n_ec.withholding.tax">
            <field name="code">332</field>
            <field name="name">RIMPE Negocio Popular / Otras Compras No Sujetas a Retención (0%)</field>
            <field name="type">renta</field>
            <field name="percentage">0.0</field>
        </record>

        <record id="tax_ret_ir_343a" model="l10n_ec.withholding.tax">
            <field name="code">343</field>
            <field name="name">RIMPE Emprendedor / Otras Retenciones 1% (1%)</field>
            <field name="type">renta</field>
            <field name="percentage">1.0</field>
        </record>

