        <!-- ========================================================= -->
        # TABLA 20: RETENCION DEL IVA (2026)
        # Nota 2026-07-08: la seccion de renta de mas arriba llevaba el
        # encabezado "TABLA 19" desde el dia 1 del fork, pero segun la
        # Ficha Tecnica oficial del SRI la Tabla 19 real es solo el
        # selector de impuesto (RENTA=1/IVA=2/ISD=6, ver
        # _RETENTION_TAX_TYPE_CODE en account_retention.py) -- el
        # catalogo de codigos por concepto de renta (303, 304, 312, etc.)
        # vive en el Catalogo del Anexo Transaccional Simplificado (ATS),
        # un documento distinto, sin numero de "Tabla" propio en la Ficha
        # Tecnica. Esta seccion de IVA si es la Tabla 20 real. No se
        # renombro el encabezado de renta para minimizar el diff de una
        # correccion puramente cosmetica (los codigos/porcentajes ya
        # auditados siguen siendo correctos, ver checkpoint 2026-07-08 en
        # CLAUDE.md).
        <!-- ========================================================= -->
        <!-- 2026-07-08: auditado contra la tabla oficial de porcentajes de
             retencion de IVA vigente. El "codigoRetencion" de cada linea
             IVA en el XML (ver retention_template.xml) no es un catalogo
             de conceptos como en Tabla 19 (renta), sino un codigo fijo
             por PORCENTAJE: 10%->9, 20%->10, 30%->1, 50%->11, 70%->2,
             100%->3. Primero verificado contra Enterprise l10n_ec_edi
             (account_move.py, diccionario L10N_EC_WITHHOLD_VAT_CODES,
             usado como referencia estructural). Bug real encontrado: el
             registro "No Procede Retencion IVA (0%)" tenia el codigo 9,
             que en realidad corresponde a 10%. Se completa ademas el
             resto de la tabla (10%, 20%, 50%), que no tenia ningun
             registro en absoluto antes.

             2026-07-08, correccion posterior el mismo dia: localizada la
             Ficha Tecnica oficial del SRI (Manual de usuario, catalogo y
             especificaciones tecnicas, v2.26, actualizada marzo-2024),
             que trae la Tabla 20 completa y distingue DOS codigos para
             0% que Enterprise colapsa en uno solo: codigo 7 = "Retencion
             en cero" (0.00%, un caso puntual segun la Disposicion
             Transitoria Unica de la Resolucion NAC-DGERCGC15-00000284) y
             codigo 8 = "No procede retencion" (0.00%, el caso general).
             El registro de este fork, semanticamente "No Procede
             Retencion", se corrige de codigo 7 a codigo 8 (el que
             realmente le corresponde por nombre); se agrega ademas un
             registro nuevo para el codigo 7 propiamente dicho. Ninguno
             de los dos tenia uso en produccion antes de esta correccion. -->

        <record id="tax_ret_iva_1" model="l10n_ec.withholding.tax">
            <field name="code">1</field>
            <field name="name">Retención IVA 30% (Bienes)</field>
            <field name="type">iva</field>
            <field name="percentage">30.0</field>
        </record>

        <record id="tax_ret_iva_2" model="l10n_ec.withholding.tax">
            <field name="code">2</field>
            <field name="name">Retención IVA 70% (Servicios)</field>
            <field name="type">iva</field>
            <field name="percentage">70.0</field>
        </record>

        <record id="tax_ret_iva_3" model="l10n_ec.withholding.tax">
            <field name="code">3</field>
            <field name="name">Retención IVA 100% (Profesionales/Arriendo/Liquidación de Compra)</field>
            <field name="type">iva</field>
            <field name="percentage">100.0</field>
        </record>

        <record id="tax_ret_iva_9" model="l10n_ec.withholding.tax">
            <field name="code">8</field>
            <field name="name">No Procede Retención IVA (0%)</field>
            <field name="type">iva</field>
            <field name="percentage">0.0</field>
        </record>

        <!-- Caso puntual: Disposición Transitoria Única de la Resolución
             NAC-DGERCGC15-00000284. No confundir con el código 8 de
             arriba (caso general de "no procede retención"). -->
        <record id="tax_ret_iva_7" model="l10n_ec.withholding.tax">
            <field name="code">7</field>
            <field name="name">Retención en Cero IVA (0%)</field>
            <field name="type">iva</field>
