<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_l10n_ec_loan_tree" model="ir.ui.view">
        <field name="name">l10n_ec.loan.tree</field>
        <field name="model">l10n_ec.loan</field>
        <field name="arch" type="xml">
            <tree string="Loans">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="loan_type"/>
                <field name="amount_total"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_l10n_ec_loan_form" model="ir.ui.view">
        <field name="name">l10n_ec.loan.form</field>
        <field name="model">l10n_ec.loan</field>
        <field name="arch" type="xml">
            <form string="Loan">
                <header>
                    <button name="action_activate" string="Activate" type="object" invisible="state != 'draft'" class="oe_highlight"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="employee_id"/>
                        </group>
                        <group>
                            <field name="loan_type"/>
                            <field name="amount_total"/>
                            <field name="date_start"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Installments">
                            <field name="installment_ids">
                                <tree editable="bottom">
                                    <field name="date_due"/>
                                    <field name="amount"/>
                                    <field name="is_paid" readonly="1"/>
                                    <field name="payslip_id" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_l10n_ec_loan" model="ir.actions.act_window">
        <field name="name">Loans &amp; Advances</field>
        <field name="res_model">l10n_ec.loan</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_l10n_ec_loan_import" model="ir.actions.act_window">
        <field name="name">Import IESS Planilla</field>
        <field name="res_model">l10n_ec.loan.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_l10n_ec_loan"
              name="Loans"
              parent="l10n_ec_hr_payroll.menu_l10n_ec_hr_payroll_root"
              action="action_l10n_ec_loan"
              sequence="30"/>

    <menuitem id="menu_l10n_ec_loan_import"
              name="Import IESS File"
              parent="menu_l10n_ec_loan"
              action="action_l10n_ec_loan_import"
              sequence="10"/>
</odoo>
