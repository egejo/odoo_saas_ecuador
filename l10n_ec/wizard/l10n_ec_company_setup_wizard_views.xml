<odoo>
    <!-- Wizard Form View -->
    <record id="l10n_ec_company_setup_wizard_form" model="ir.ui.view">
        <field name="name">l10n_ec.company.setup.wizard.form</field>
        <field name="model">l10n_ec.company.setup.wizard</field>
        <field name="arch" type="xml">
            <form string="🇪🇨 Configurar Empresa Ecuador">
                <div class="text-center mb-4">
                    <h2>🇪🇨 Configuración de Empresa Ecuador</h2>
                    <p class="text-muted">Complete los datos de su empresa para cumplir con las regulaciones del SRI</p>
                </div>

                <group>
                    <group string="📋 Datos de la Empresa" name="company_info">
                        <field name="company_name" placeholder="Ej: Mi Empresa S.A."/>
                        <field name="company_ruc" placeholder="Ej: 1791234567001"/>
                        <field name="commercial_name" placeholder="Nombre comercial (opcional)"/>
                    </group>

                    <group string="📍 Dirección" name="address">
                        <field name="street" placeholder="Av. Principal 123"/>
                        <field name="city" placeholder="Quito"/>
                        <field name="province_id" placeholder="Seleccione provincia"/>
                        <field name="phone" placeholder="+593 2 1234567"/>
                        <field name="email" placeholder="info@miempresa.ec"/>
                        <field name="website" placeholder="www.miempresa.ec"/>
                    </group>
                </group>

                <group string="⚙️ Configuración SRI" name="sri_settings">
                    <group>
                        <field name="sri_environment" widget="radio"/>
                        <field name="obligado_contabilidad"/>
                    </group>
                    <group>
                        <field name="contribuyente_especial" placeholder="Nº resolución (si aplica)"/>
                        <field name="agente_retencion" placeholder="Nº resolución (si aplica)"/>
                    </group>
                </group>

                <div class="alert alert-info" role="alert">
                    <strong>💡 Nota:</strong> Puede modificar estos datos posteriormente en
                    <strong>Ajustes → Empresas</strong>
                </div>

                <footer>
                    <button name="action_configure_company"
                            string="✅ Configurar Empresa"
                            type="object"
                            class="btn-primary"/>
                    <button name="action_skip_wizard"
                            string="Configurar Después"
                            type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open wizard -->
    <record id="action_l10n_ec_company_setup_wizard" model="ir.actions.act_window">
        <field name="name">Configurar Empresa Ecuador</field>
        <field name="res_model">l10n_ec.company.setup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'form_view_initial_mode': 'edit'}</field>
    </record>

    <!-- Menu item (optional, in Settings) -->
    <menuitem id="menu_l10n_ec_company_setup"
              name="Configurar Empresa Ecuador"
              parent="base.menu_administration"
              action="action_l10n_ec_company_setup_wizard"
              sequence="1"/>
</odoo>
