<odoo>
    <!-- Wizard Form View -->
    <record id="l10n_ec_company_setup_wizard_form" model="ir.ui.view">
        <field name="name">l10n_ec.company.setup.wizard.form</field>
        <field name="model">l10n_ec.company.setup.wizard</field>
        <field name="arch" type="xml">
            <form string="🇪🇨 Configurar Empresa Ecuador">
                <div class="text-center mb-4">
                    <h2>🇪🇨 Configuración de Empresa Ecuador</h2>
                    <p class="text-muted">Ingrese el RUC y los datos se cargarán automáticamente del SRI</p>
                </div>

                <!-- Search Section -->
                <group string="🔍 Buscar en SRI" name="search">
                    <group>
                        <field name="company_ruc" placeholder="Ingrese RUC de 13 dígitos..."
                               class="oe_inline" style="font-size: 1.2em; font-weight: bold;"/>
                    </group>
                    <group>
                        <field name="sri_message" readonly="1"
                               class="oe_inline text-info"/>
                    </group>
                </group>

                <!-- SRI Loaded Data -->
                <group string="📋 Datos del Contribuyente (SRI)" name="company_info"
                       invisible="not sri_loaded">
                    <group>
                        <field name="company_name" readonly="0"/>
                        <field name="commercial_name"/>
                        <field name="sri_estado" class="text-success"/>
                        <field name="sri_tipo_contribuyente"/>
                    </group>
                    <group>
                        <field name="sri_clase_contribuyente"/>
                        <field name="sri_actividad"/>
                        <field name="regimen_rimpe" invisible="not regimen_rimpe"/>
                        <field name="sri_loaded" invisible="1"/>
                    </group>
                </group>

                <!-- Address Section -->
                <group string="📍 Dirección" name="address" invisible="not sri_loaded">
                    <group>
                        <field name="street"/>
                        <field name="city"/>
                        <field name="province"/>
                    </group>
                    <group>
                        <field name="phone"/>
                        <field name="email"/>
                        <field name="website"/>
                    </group>
                </group>

                <!-- SRI Settings -->
                <group string="⚙️ Configuración Tributaria" name="sri_settings"
                       invisible="not sri_loaded">
                    <group>
                        <field name="sri_environment" widget="radio"/>
                        <field name="obligado_contabilidad"/>
                    </group>
                    <group>
                        <field name="contribuyente_especial"
                               invisible="not contribuyente_especial"/>
                        <field name="agente_retencion"
                               invisible="not agente_retencion"/>
                    </group>
                </group>

                <div class="alert alert-info" role="alert" invisible="not sri_loaded">
                    <strong>💡 Datos cargados automáticamente del SRI.</strong>
                    Puede modificar los campos si es necesario.
                </div>

                <div class="alert alert-warning" role="alert" invisible="sri_loaded">
                    <strong>💡 Ingrese el RUC de su empresa</strong> para cargar los datos
                    automáticamente desde el SRI.
                </div>

                <footer>
                    <button name="action_configure_company"
                            string="✅ Configurar Empresa"
                            type="object"
                            class="btn-primary"
                            invisible="not sri_loaded"/>
                    <button name="action_skip_wizard"
                            string="Configurar Después"
                            type="object"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open wizard -->
    <record id="action_l10n_ec_company_setup_wizard" model="ir.actions.act_window">
        <field name="name">Configurar Empresa Ecuador</field>
        <field name="res_model">l10n_ec.company.setup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'form_view_initial_mode': 'edit'}</field>
    </record>

    <!-- Menu item in Settings -->
    <menuitem id="menu_l10n_ec_company_setup"
              name="🇪🇨 Configurar Empresa Ecuador"
              parent="base.menu_administration"
              action="action_l10n_ec_company_setup_wizard"
              sequence="1"/>
</odoo>
