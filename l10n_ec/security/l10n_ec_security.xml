<?xml version="1.0" encoding="utf-8"?>
<!--
    Security Groups - Ecuador Localization
    =======================================
    Implements RO 395-2025 (Auditor de Transparencia)

    Copyright 2026 Somatech.dev
-->
<odoo>
    <data noupdate="0">

        <!-- ================================================================
             SECURITY CATEGORY
             ================================================================ -->
        <record id="module_category_l10n_ec" model="ir.module.category">
            <field name="name">Ecuador Localization</field>
            <field name="description">Ecuador Localization Security Groups</field>
            <field name="sequence">100</field>
        </record>

        <!-- ================================================================
             AUDITOR DE TRANSPARENCIA (RO 395-2025)
             Read-only access to all audit logs and SRI transmissions
             ================================================================ -->
        <record id="group_auditor_transparencia" model="res.groups">
            <field name="name">Auditor de Transparencia</field>
            <field name="comment">
                Rol de solo lectura para auditoría de licitaciones y transmisiones SRI.
                Implementa RO 395-2025 del SRI Ecuador.
                - Puede ver todos los logs de transmisión SRI
                - Puede ver historial de facturas electrónicas
                - Puede ver logs de retenciones
                - NO puede modificar ni crear documentos
            </field>
            <field name="category_id" ref="module_category_l10n_ec"/>
        </record>

        <!-- ================================================================
             ECUADOR ACCOUNTANT - Full access to localization
             ================================================================ -->
        <record id="group_ec_accountant" model="res.groups">
            <field name="name">Contador Ecuador</field>
            <field name="comment">
                Acceso completo a funcionalidades de localización Ecuador.
                - Facturación electrónica
                - Retenciones
                - ATS
                - Guía de Remisión
            </field>
            <field name="category_id" ref="module_category_l10n_ec"/>
            <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
        </record>

        <!-- ================================================================
             ECUADOR MANAGER - Administration access
             ================================================================ -->
        <record id="group_ec_manager" model="res.groups">
            <field name="name">Administrador Ecuador</field>
            <field name="comment">
                Administración de certificados, configuración SRI.
            </field>
            <field name="category_id" ref="module_category_l10n_ec"/>
            <field name="implied_ids" eval="[(4, ref('group_ec_accountant'))]"/>
        </record>

    </data>
</odoo>
