<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_l10n_ec_delivery_guide" model="ir.ui.view">
        <field name="name">res.company.form.l10n_ec_delivery_guide</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="l10n_ec_edi.view_company_form_l10n_ec_edi"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='l10n_ec_sri']/group" position="inside">
                <group string="Guía de Remisión">
                    <field name="l10n_ec_delivery_guide_establishment"/>
                    <field name="l10n_ec_delivery_guide_emission_point"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
