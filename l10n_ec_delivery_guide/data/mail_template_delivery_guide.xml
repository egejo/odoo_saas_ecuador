<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate="1": mismo criterio que mail_template_retention.xml
         (l10n_ec_withholding). El usuario puede personalizarla desde
         Ajustes > Técnico > Plantillas de Correo sin que una
         actualización de módulo la pise. -->
    <data noupdate="1">
        <record id="mail_template_delivery_guide" model="mail.template">
            <field name="name">Guía de Remisión: Envío al Destinatario</field>
            <field name="model_id" ref="l10n_ec_delivery_guide.model_l10n_ec_delivery_guide"/>
            <field name="email_from">{{ (object.company_id.email_formatted or user.email_formatted) }}</field>
            <field name="partner_to">{{ object.partner_id.id }}</field>
            <field name="subject">{{ object.company_id.name }}: Guía de Remisión {{ object.name or '' }}</field>
            <field name="description">Enviado al destinatario al presionar "Enviar por Correo" en una guía de remisión autorizada</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Estimados
        <t t-out="object.partner_id.name or ''">Cliente</t>,
        <br/><br/>
        Adjunto la Guía de Remisión
        <span style="font-weight:bold;" t-out="object.name or ''">001-001-000000001</span>
        emitida por
        <t t-out="object.company_id.name or ''">Adrenalina Action Sports Adrenasports Cia. LTDA.</t>
        correspondiente al traslado con fecha de inicio
        <t t-out="format_date(object.date_start) or ''">01/01/2026</t>.
        <br/><br/>
        Se adjuntan ambos archivos del comprobante electrónico: la
        representación impresa (RIDE) en PDF y el XML autorizado por el
        SRI, tal como exige la normativa vigente para la entrega de
        comprobantes electrónicos.
        <br/><br/>
        Clave de acceso:
        <span t-out="object.l10n_ec_sri_access_key or ''">0000000000000000000000000000000000000000000000</span>
        <br/><br/>
        Cualquier consulta sobre este comprobante, no dude en
        contactarnos.
        <br/><br/>
        Saludos cordiales,
        <br/>
        <t t-out="object.company_id.name or ''">Adrenalina Action Sports Adrenasports Cia. LTDA.</t>
        <t t-if="object.company_id.phone">
            <br/>Tel: <t t-out="object.company_id.phone"/>
        </t>
        <t t-if="object.company_id.email">
            <br/>Email: <t t-out="object.company_id.email"/>
        </t>
        <t t-if="object.company_id.website">
            <br/><a t-att-href="object.company_id.website" t-out="object.company_id.website"/>
        </t>
    </p>
</div>
            </field>
            <field name="report_template_ids" eval="[]"/>
            <field name="lang">{{ object.partner_id.lang }}</field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>
</odoo>
